{
  "name": "proviso",
  "build": {
    "dockerfile": "../Dockerfile.devcontainer",
    "context": "..",
    "args": {
      // ── Point at your pre-built tools image (from build.sh --push-tools) ──
      // "TOOLS_IMAGE": "registry.corp.com/dev-tools:latest"
      "TOOLS_IMAGE": "proviso-dev-tools:latest",
      "USERNAME": "devuser",
      "USER_UID": "1000"
    }
  },

  // ── Bind mount: your code directory ──────────────────────────────────────
  // This is NOT a copy. Both sides see the same files in real time.
  // Edit on your Mac → container sees it instantly. No rebuild needed.
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    // X11 socket (XQuartz on Mac, Xorg on Linux)
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,optional=true",
    // Wayland socket (Linux only — path is $XDG_RUNTIME_DIR/$WAYLAND_DISPLAY)
    "source=${localEnv:XDG_RUNTIME_DIR},target=/run/user/host,type=bind,optional=true",
    // [proviso:mounts:begin] — managed by `parcel gen-devcontainer`, do not edit
    "source=${localEnv:HOME}/.proviso/dotfiles,target=/proviso/dotfiles,type=bind,consistency=cached,optional=true",
    // [proviso:mounts:end]
  ],

  // ── Display passthrough (X11 or Wayland — whichever the host uses) ─────────
  "containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}",
    "WAYLAND_DISPLAY": "${localEnv:WAYLAND_DISPLAY}",
    "XDG_RUNTIME_DIR": "/run/user/host"
  },
  "workspaceFolder": "/workspace",

  // ── VS Code extensions (installed inside the container) ──────────────────
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        "github.vscode-github-actions",
        "mhutchie.git-graph",
        "eamodio.gitlens",
        "asvetliakov.vscode-neovim"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        },
        "terminal.integrated.defaultProfile.linux": "fish"
      }
    }
  },

  // ── Lifecycle hooks ───────────────────────────────────────────────────────
  // postCreateCommand: runs ONCE when the container is first created
  "postCreateCommand": "bash /workspace/.devcontainer/setup.sh",

  // postStartCommand: runs EVERY time the container starts
  "postStartCommand": "echo \"Branch: $(git -C /workspace branch --show-current 2>/dev/null) | Python: $(uv run python --version 2>&1 | head -1)\"",

  // Run as the non-root devuser
  "remoteUser": "devuser",

  // Forward ports if your project has a dev server
  "forwardPorts": []
}
